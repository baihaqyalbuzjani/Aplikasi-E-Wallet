ALGORITMA E-MONEY

KAMUS GLOBAL

CONST MAX = 100

TYPE Akun :
id : string
pin : integer
saldo : integer
status : string

TYPE Transaksi :
idAkun : string
jenis : string
jumlah : integer
keterangan : string

A : array[0..MAX-1] of Akun
T : array[0..MAX-1] of Transaksiiy

n : integer
nt : integer

FUNCTION KonversiUang(s : string) -> integer

KAMUS LOKAL
i, hasil : integer

ALGORITMA
hasil <- 0

```
UNTUK i <- 0 sampai panjang(s)-1
    JIKA s[i] <> '.'
        hasil <- hasil * 10 + digit(s[i])
    AKHIRJIKA
AKHIRUNTUK

RETURN hasil
```

FUNCTION CariAkun(A,n,id) -> integer

KAMUS LOKAL
i : integer

ALGORITMA
UNTUK i <- 0 sampai n-1
JIKA A[i].id = id
RETURN i
AKHIRJIKA
AKHIRUNTUK

```
RETURN -1
```

PROCEDURE Registrasi(A,n)

KAMUS LOKAL
id : string
pin : integer

ALGORITMA
INPUT id
INPUT pin

```
JIKA CariAkun(A,n,id) <> -1
    OUTPUT "ID sudah digunakan"
LAIN
    A[n].id <- id
    A[n].pin <- pin
    A[n].saldo <- 0
    A[n].status <- "pending"

    n <- n + 1

    OUTPUT "Registrasi berhasil"
AKHIRJIKA
```

PROCEDURE Admin(A,n)

KAMUS LOKAL
i, pilih : integer

ALGORITMA
UNTUK i <- 0 sampai n-1

```
    JIKA A[i].status = "pending"

        OUTPUT A[i].id
        INPUT pilih

        JIKA pilih = 1
            A[i].status <- "aktif"
        LAIN
            A[i].status <- "ditolak"
        AKHIRJIKA

    AKHIRJIKA

AKHIRUNTUK
```

PROCEDURE CetakAkun(A,n)

KAMUS LOKAL
i : integer

ALGORITMA
UNTUK i <- 0 sampai n-1

```
    OUTPUT
        A[i].id,
        A[i].status,
        A[i].saldo

AKHIRUNTUK
```

FUNCTION Login(A,n) -> integer

KAMUS LOKAL
id : string
pin : integer
idx : integer

ALGORITMA
INPUT id
INPUT pin

```
idx <- CariAkun(A,n,id)

JIKA idx = -1
    RETURN -1
AKHIRJIKA

JIKA A[idx].status <> "aktif"
    RETURN -1
AKHIRJIKA

JIKA A[idx].pin <> pin
    RETURN -1
AKHIRJIKA

RETURN idx
```

PROCEDURE TopUp(idx,A,T,nt)

KAMUS LOKAL
input : string
jumlah : integer

ALGORITMA
INPUT input

```
jumlah <- KonversiUang(input)

A[idx].saldo <- A[idx].saldo + jumlah

T[nt].idAkun <- A[idx].id
T[nt].jenis <- "TopUp"
T[nt].jumlah <- jumlah
T[nt].keterangan <- "-"

nt <- nt + 1
```

PROCEDURE Transfer(idx,A,n,T,nt)

KAMUS LOKAL
idTujuan : string
input : string
jumlah : integer
idxTujuan : integer

ALGORITMA
INPUT idTujuan

```
idxTujuan <- CariAkun(A,n,idTujuan)

JIKA idxTujuan = -1
    OUTPUT "Akun tidak ditemukan"
LAIN

    INPUT input
    jumlah <- KonversiUang(input)

    JIKA A[idx].saldo >= jumlah

        A[idx].saldo <- A[idx].saldo - jumlah
        A[idxTujuan].saldo <- A[idxTujuan].saldo + jumlah

        T[nt].idAkun <- A[idx].id
        T[nt].jenis <- "Transfer"
        T[nt].jumlah <- jumlah
        T[nt].keterangan <- "Keluar"

        nt <- nt + 1

    LAIN

        OUTPUT "Saldo tidak cukup"

    AKHIRJIKA

AKHIRJIKA
```

PROCEDURE Pembayaran(idx,A,T,nt)

KAMUS LOKAL
pilih : integer
input : string
jumlah : integer
layanan : string

ALGORITMA
INPUT pilih

```
TENTUKAN layanan

INPUT input

jumlah <- KonversiUang(input)

JIKA saldo cukup

    A[idx].saldo <- A[idx].saldo - jumlah

    T[nt].idAkun <- A[idx].id
    T[nt].jenis <- "Pembayaran"
    T[nt].jumlah <- jumlah
    T[nt].keterangan <- layanan

    nt <- nt + 1

LAIN

    OUTPUT "Saldo tidak cukup"

AKHIRJIKA
```

PROCEDURE SelectionSort(T,nt)

KAMUS LOKAL
i,j,max : integer
temp : Transaksi

ALGORITMA

```
UNTUK i <- 0 sampai nt-2

    max <- i

    UNTUK j <- i+1 sampai nt-1

        JIKA T[j].jumlah > T[max].jumlah
            max <- j
        AKHIRJIKA

    AKHIRUNTUK

    TUKAR T[i] dengan T[max]

AKHIRUNTUK
```

PROCEDURE Riwayat(idx,A,T,nt)

KAMUS LOKAL
pilih,i : integer

ALGORITMA
INPUT pilih

```
JIKA pilih = 2
    SelectionSort(T,nt)
AKHIRJIKA

UNTUK i <- 0 sampai nt-1

    JIKA T[i].idAkun = A[idx].id
        OUTPUT
            T[i].jenis,
            T[i].jumlah,
            T[i].keterangan
    AKHIRJIKA

AKHIRUNTUK

OUTPUT saldo pengguna

PROGRAM UTAMA

KAMUS LOKAL

A : array[0..MAX-1] of Akun
T : array[0..MAX-1] of Transaksi

n : integer
nt : integer

pilih : integer
idx : integer

ALGORITMA

n <- 0
nt <- 0

ULANGI

```
OUTPUT "===== E-MONEY ====="
OUTPUT "1. Registrasi"
OUTPUT "2. Login"
OUTPUT "3. Admin"
OUTPUT "4. Keluar"

INPUT pilih

JIKA pilih = 1

    Registrasi(A,n)

LAINJIKA pilih = 2

    idx <- Login(A,n)

    JIKA idx <> -1

        ULANGI

            OUTPUT "===== MENU USER ====="
            OUTPUT "1. Transfer"
            OUTPUT "2. Top Up"
            OUTPUT "3. Pembayaran"
            OUTPUT "4. Riwayat"
            OUTPUT "5. Logout"

            INPUT pilih

            JIKA pilih = 1

                Transfer(idx,A,n,T,nt)

            LAINJIKA pilih = 2

                TopUp(idx,A,T,nt)

            LAINJIKA pilih = 3

                Pembayaran(idx,A,T,nt)

            LAINJIKA pilih = 4

                Riwayat(idx,A,T,nt)

            AKHIRJIKA

        SAMPAI pilih = 5

    AKHIRJIKA

LAINJIKA pilih = 3

    ULANGI

        OUTPUT "===== MENU ADMIN ====="
        OUTPUT "1. Approve / Tolak Akun"
        OUTPUT "2. Cetak Daftar Akun"
        OUTPUT "3. Kembali"

        INPUT pilih

        JIKA pilih = 1

            Admin(A,n)

        LAINJIKA pilih = 2

            CetakAkun(A,n)

        AKHIRJIKA

    SAMPAI pilih = 3

AKHIRJIKA

SAMPAI pilih = 4

OUTPUT "Program selesai"
